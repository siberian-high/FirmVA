# .env 예시
# 이 파일을 복사해 ".env"를 생성하고 값을 설정
# .env 는 .gitignore에 등록되어 업로드 되지 않음
# cp .env.example .env


# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ghidra MCP (LaurieWired/GhidraMCP)
GHIDRA_MCP_URL=http://127.0.0.1:8081/sse

# QEMU MCP
QEMU_MCP_URL=http://127.0.0.1:8090/sse

# Target Firmware
TARGET_NAME=

# Demo Mode
# true : 도구 및 키가 없어도 파이프라인 전체를 데모 데이터를 사용해 끝까지 테스트
# false: 실제 binwalk/Ghidra/QEMU/LLM을 호출해 사용
DEMO_MODE=true
